local BoltCache = PartCache.new(BoltTemplate, 1000, Workspace.Terrain)

-- CFrame correction so a cylinder "points" along its length toward lookAt target
local LOOK_INVERSE = CFrame.lookAt(Vector3.new(), Vector3.new(1, 0, 0)):Inverse()
local ActiveBolts  = {}

-- Cubic Bézier
local function BezierCurve(t, p0, p1, p2, p3)
	local u = 1 - t
	return u^3*p0 + 3*u^2*t*p1 + 3*u*t^2*p2 + t^3*p3
end

-- Opacity envelope for the travelling-pulse effect
local function OpacityProfile(posRatio, elapsed, pulseSpeed, pulseLength, fadeLength, minOp, maxOp)
	local center     = pulseLength / (2 * fadeLength)
	local normalized = (posRatio - elapsed * pulseLength + 0.5 * pulseLength) / fadeLength
	local proximity  = center - math.abs(normalized)
	return math.clamp(proximity, minOp, math.max(maxOp, minOp))
end

-- Gaussian-like radial profile that tapers at both ends
local function RadialProfile(t)
	return math.exp(-5000 * (t - 0.5)^10)
end

local LightningBolt   = {}
LightningBolt.__index = LightningBolt

function LightningBolt.new(att0, att1, partCount)
	local self = setmetatable({}, LightningBolt)
	self.Enabled                = true
	self.Attachment0            = att0
	self.Attachment1            = att1
	self.CurveSize0             = 0
	self.CurveSize1             = 0
	self.MinRadius              = 0
	self.MaxRadius              = 2.4
	self.Frequency              = 1
	self.AnimationSpeed         = 7
	self.Thickness              = 1
	self.MinThicknessMultiplier = 0.2
	self.MaxThicknessMultiplier = 1
	self.MinTransparency        = 0
	self.MaxTransparency        = 1
	self.PulseSpeed             = 2
	self.PulseLength            = 1000000
	self.FadeLength             = 0.2
	self.ContractFrom           = 0.5
	self.Color                  = Color3.fromRGB(255, 86, 30)
	self.ColorOffsetSpeed       = 3
	self.SpaceCurveFunction     = BezierCurve
	self.OpacityProfileFunction = OpacityProfile
	self.RadialProfileFunction  = RadialProfile
	self._Parts                 = {}
	for i = 1, partCount or 30 do
		self._Parts[i] = BoltCache:GetPart()
	end
	self._PartsHidden          = false
	self._DisabledTransparency = 1
	self._StartT               = os.clock()
	self._RanNum               = math.random() * 100
	self._RefIndex             = #ActiveBolts + 1
	ActiveBolts[self._RefIndex] = self
	return self
end

function LightningBolt:Destroy()
	ActiveBolts[self._RefIndex] = nil
	for i = 1, #self._Parts do
		if BoltCache:IsPartInUse(self._Parts[i]) then
			BoltCache:ReturnPart(self._Parts[i])
		end
	end
end

function LightningBolt:DestroyDissipate(fadeTime, expandFactor)
	local duration       = fadeTime     or 0.2
	local expand         = expandFactor or 0.5
	local startT         = os.clock()
	local origMinTrans   = self.MinTransparency
	local origContract   = self.ContractFrom
	local contractEdge   = self.ContractFrom + 1 / (#self._Parts * self.FadeLength)
	local origMaxRadius  = self.MaxRadius
	local origMinThick   = self.MinThicknessMultiplier
	local conn
	conn = RunService.Heartbeat:Connect(function()
		local e = os.clock() - startT
		self.MinThicknessMultiplier = origMinThick + (-2 - origMinThick) * e / duration
		if e < duration * 0.4 then
			local t = e / (duration * 0.4)
			self.MinTransparency = origMinTrans + (origContract - origMinTrans) * t
		elseif e < duration then
			local t = (e - duration * 0.4) / (duration * 0.6)
			self.MinTransparency = origContract + (contractEdge - origContract) * t
			self.MaxRadius       = origMaxRadius * (1 + expand * t)
			self.MinRadius       = self.MinRadius + (self.MaxRadius - self.MinRadius) * t
		else
			if os.clock() - self._StartT < (self.PulseLength + 1) / self.PulseSpeed then
				self:Destroy()
			end
			conn:Disconnect()
			conn = nil
		end
	end)
end

function LightningBolt:_UpdateGeometry(part, posRatio, elapsed, thickMult, segStart, segEnd)
	local minOp    = 1 - self.MaxTransparency
	local maxOp    = 1 - self.MinTransparency
	local opacity  = self.OpacityProfileFunction(posRatio, elapsed, self.PulseSpeed, self.PulseLength, self.FadeLength, minOp, maxOp)
	local thick    = self.Thickness * thickMult * opacity
	local visOp    = thick > 0 and opacity or 0
	local cThresh  = 1 - self.ContractFrom
	local n        = #self._Parts

	if cThresh < visOp then
		local len     = (segEnd - segStart).Magnitude
		part.Size     = Vector3.new(len, thick, thick)
		part.CFrame   = CFrame.lookAt((segStart + segEnd) * 0.5, segEnd) * LOOK_INVERSE
		part.Transparency = 1 - visOp
	elseif cThresh - 1 / (n * self.FadeLength) < visOp then
		local fadeEdge  = cThresh - 1 / (n * self.FadeLength)
		local dir       = (posRatio < elapsed * self.PulseSpeed - 0.5 * self.PulseLength) and 1 or -1
		local edgeFac   = (1 - (visOp - fadeEdge) * n * self.FadeLength) * dir
		local segLen    = (1 - math.abs(edgeFac)) * (segEnd - segStart).Magnitude
		part.Size       = Vector3.new(segLen, thick, thick)
		part.CFrame     = CFrame.lookAt(segStart + (segEnd - segStart) * (math.max(0, edgeFac) + (1 - math.abs(edgeFac)) * 0.5), segEnd) * LOOK_INVERSE
		part.Transparency = 1 - visOp
	else
		part.Transparency = 1
	end
end

function LightningBolt:_UpdateColor(part, posRatio, elapsed)
	local color = self.Color
	if typeof(color) == "Color3" then
		part.Color = color
	else
		local offset = (self._RanNum + posRatio - elapsed * self.ColorOffsetSpeed) % 1
		local kps    = color.Keypoints
		for i = 1, #kps - 1 do
			if kps[i].Time < offset and offset < kps[i+1].Time then
				part.Color = kps[i].Value:Lerp(kps[i+1].Value,
					(offset - kps[i].Time) / (kps[i+1].Time - kps[i].Time))
				return
			end
		end
	end
end

function LightningBolt:_Disable()
	self.Enabled = false
	for _, p in ipairs(self._Parts) do
		p.Transparency = self._DisabledTransparency
	end
end

-- Bolt update loop
RunService.Heartbeat:Connect(function()
	debug.profilebegin("LightningBolt")
	for _, bolt in pairs(ActiveBolts) do
		if bolt.Enabled then
			bolt._PartsHidden = false
			local minR     = bolt.MinRadius
			local maxR     = bolt.MaxRadius
			local parts    = bolt._Parts
			local n        = #parts
			local ranNum   = bolt._RanNum
			local animSpd  = bolt.AnimationSpeed
			local freq     = bolt.Frequency
			local minThick = bolt.MinThicknessMultiplier
			local maxThick = bolt.MaxThicknessMultiplier
			local elapsed  = os.clock() - bolt._StartT
			local curve    = bolt.SpaceCurveFunction
			local radial   = bolt.RadialProfileFunction
			local maxTime  = (bolt.PulseLength + 1) / bolt.PulseSpeed
			local att0     = bolt.Attachment0
			local att1     = bolt.Attachment1
			local p0       = att0.WorldPosition
			local p1       = p0 + att0.WorldAxis * bolt.CurveSize0
			local p2       = att1.WorldPosition - att1.WorldAxis * bolt.CurveSize1
			local p3       = att1.WorldPosition

			if elapsed < maxTime then
				local prevCurve = curve(0, p0, p1, p2, p3)
				local prevPart  = prevCurve
				for i = 1, n do
					local part = parts[i]
					local t    = i / n
					-- Noise coordinates
					local a    = animSpd * -elapsed + freq * 10 * t - 0.2 + ranNum * 4
					local b    = 5 * (animSpd * 0.001 * -elapsed + freq * t) + ranNum * 4
					-- Combined rotation angle for displacement
					local ang1 = 0.6283185307179586  * (math.noise(5 * a, 1.5, b)       + 0.5)
					local ang2 = 5.654866776461628   * (math.noise(0.5 * a, 1.5, 0.1*b) + 0.5)
					local angle = ang1 + ang2
					-- Displacement radius and thickness
					local radius    = (minR + (maxR - minR) * (math.noise(3.4, b, a) + 0.5)) * radial(t)
					local thickMult = minThick + (maxThick - minThick) * (math.noise(2.3, b, a) + 0.5)
					local curvePos  = curve(t, p0, p1, p2, p3)
					local partPos
					if i == n then
						partPos = curvePos
					else
						local lookCF   = CFrame.new(prevCurve, curvePos) * CFrame.Angles(0, 0, angle)
						local noiseVal = math.clamp(6.123233995736766e-17 + 0.9999999999999999 * (math.noise(b, a, 2.7) + 0.5), -1, 1)
						partPos = (lookCF * CFrame.Angles(math.acos(noiseVal), 0, 0) * CFrame.new(0, 0, -radius)).Position or curvePos
					end
					bolt:_UpdateGeometry(part, t, elapsed, thickMult, prevPart, partPos)
					bolt:_UpdateColor(part, t, elapsed)
					prevCurve = curvePos
					prevPart  = partPos
				end
			else
				bolt:Destroy()
			end
		elseif not bolt._PartsHidden then
			bolt._PartsHidden = true
			bolt:_Disable()
		end
	end
	debug.profileend()
end)

