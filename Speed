local VFX          = { Users = {} }
local _lastTrailType = nil   -- tracks Primary/Secondary alternation during setup

-- Helper: is the colour so dark it needs no light emission?
local function IsDark(color)
	if typeof(color) == "ColorSequence" then color = color.Keypoints[1].Value end
	return 0.299*color.R + 0.587*color.G + 0.114*color.B < 0.1
end

-- Remove all VFX data for a character
local function DestroyUserTable(character)
	character:SetAttribute("LastPos", nil)
	local entry = VFX.Users[character]
	if entry and entry[2] then entry[2]:Disconnect() end
	local trails = character:FindFirstChild("CW_Trails")
	if trails then
		for _, t in pairs(trails:GetChildren()) do
			if t:IsA("Trail") then
				if t.Attachment0 then t.Attachment0:Destroy() end
				if t.Attachment1 then t.Attachment1:Destroy() end
				t:Destroy()
			end
		end
		trails:Destroy()
	end
	for _, part in pairs(character:GetChildren()) do
		if part:IsA("BasePart") then
			local p = part:FindFirstChild("CW_Particle")
			if p then
				p.Name    = "DESTROYING"
				p.Enabled = false
				Debris:AddItem(p, 1)
			end
		end
	end
	VFX.Users[character] = nil
end

local function CreateTrail()
	local t    = BuildTrailInstance()
	t.Lifetime = 0.2
	return t
end

-- Randomise the two attachment positions for a given trail
local function NewAttachmentPositions(hipScale, yOffset)
	local x    = math.random(-200, 200) / 100
	local y    = yOffset + math.random(-50, 50) / 100 * hipScale
	local base = Vector3.new(x, y, 0)
	local dir  = (math.random() < 0.5 and -1 or 1)
	return base, base + Vector3.new(0, dir, 0)
end

-- Pick a random valid body part that exists on the default rig
local function RandomBodyPart(character)
	local valid = {}
	for _, p in pairs(character:GetChildren()) do
		if p:IsA("BasePart")
			and VALID_BODY_PARTS[p.Name]
			and p:FindFirstChildOfClass("Attachment") then
			table.insert(valid, p)
		end
	end
	return valid[math.random(1, #valid)]
end

-- Create an attachment anchored to UpperTorso (used for trail endpoints)
local function CreateTorsoAttachment(character)
	local att    = Instance.new("Attachment")
	att.Parent   = character:WaitForChild("UpperTorso")
	return att
end

-- Create an attachment placed randomly on a surface of a random body part
local function CreateRandomlyPlacedAttachment(character)
	local bp  = RandomBodyPart(character)
	local att = Instance.new("Attachment")
	att.Parent = bp
	local sx, sy, sz = bp.Size.X * 0.5, bp.Size.Y * 0.5, bp.Size.Z * 0.5
	local side = math.random(1, 3)
	local function rnd(lo, hi) return math.random(math.floor(lo*100), math.floor(hi*100)) / 100 end
	local face = math.pow(-1, math.random(0, 1))
	if side == 1 then
		att.Position = Vector3.new(sx * face, rnd(-sy, sy), rnd(-sz, sz))
	elseif side == 2 then
		att.Position = Vector3.new(rnd(-sx, sx), sy * face, rnd(-sz, sz))
	else
		att.Position = Vector3.new(rnd(-sx, sx), rnd(-sy, sy), sz * face)
	end
	return att
end

-- Resolve which colour to display for this character's lightning
local function GetLightningColor()
	return TRAIL_COLOR
end

-- Spawn a brief point light at a random location on the body
local function IdleLight(character, color)
	local att          = CreateRandomlyPlacedAttachment(character)
	local light        = Instance.new("PointLight")
