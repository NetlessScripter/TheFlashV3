-- ============================================================
local PartCache    = {}
PartCache.__index  = PartCache

function PartCache.new(template, precount, parent)
	local self      = setmetatable({}, PartCache)
	self._template  = template
	self._parent    = parent or Workspace.Terrain
	self._available = {}
	self._inUse     = {}

	for _ = 1, precount do
		local p     = template:Clone()
		p.CFrame    = CFrame.new(0, 1e8, 0)
		p.Parent    = self._parent
		table.insert(self._available, p)
	end
	return self
end

function PartCache:SetCacheParent(newParent)
	self._parent = newParent
	for _, p in ipairs(self._available)   do p.Parent = newParent end
	for  p      in pairs(self._inUse)     do p.Parent = newParent end
end

function PartCache:GetPart()
	local p
	if #self._available > 0 then
		p = table.remove(self._available)
	else
		p        = self._template:Clone()
		p.Parent = self._parent
	end
	self._inUse[p] = true
	return p
end

function PartCache:ReturnPart(p)
	if self._inUse[p] then
		self._inUse[p] = nil
		p.CFrame        = CFrame.new(0, 1e8, 0)
		table.insert(self._available, p)
	end
end

function PartCache:IsPartInUse(p)
	return self._inUse[p] == true
end

