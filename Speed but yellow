    BOOST_LOOP    = "rbxassetid://16125237685",  -- looped after startup completes
}

-- ── 3b. Sound IDs ─────────────────────────────────
local SOUNDS = {
    RUN_START     = "rbxassetid://15432643319",
    RUN_STOP      = "rbxassetid://15432643405",
    RUN_LOOP      = "rbxassetid://18997258379",
    IDLE          = "rbxassetid://96900367829680",
    SLIDE         = "rbxassetid://9775087198",
    BOOST_RELEASE = "rbxassetid://16536538664",
    BOOST_CHARGE  = "rbxassetid://115241322457935",
}

-- ── 4. Threshold ──────────────────────────────────
local SPEED_RUN = 145

-- ── 5. State ──────────────────────────────────────
local currentState = nil  -- "idle" | "fastrun" | "jump" | "jumploop"

-- ── 6. Helpers ────────────────────────────────────
local BASE_SPEED = 16
local function calcPlaybackSpeed(ws)
    return math.max(0.5, ws / BASE_SPEED)
end

local function flushAnimatorTracks()
    local animator = humanoid:FindFirstChildOfClass("Animator")
    if not animator then return end
    for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
        track:Stop(0)
    end
end

local function playAnim(id, speed, looped)
    flushAnimatorTracks()
    getgenv().Animator6D(id, speed, looped)
end

local function stopAnim()
    flushAnimatorTracks()
    if getgenv().Animator6DStop then
        getgenv().Animator6DStop()
    end
end

local function setLiveSpeed(speed)
    local anim = getgenv().currentAnimator6D
    if anim and math.abs((anim.speed or 0) - speed) > 0.05 then
        anim.speed = speed
    end
end

-- ── 7. State machine ──────────────────────────────
local function transitionTo(newState, ws)
    if not speedEnabled then return end   -- don't run any anim/sound logic if speed is off
    if boostCharging    then return end   -- don't override charge boost animations
    if newState == currentState then return end
    currentState = newState

    if newState == "idle" then
        setEffectEnabled(false)
        -- If a slide happens during the 8-second boost window, snap BURST_START back to default
        if boostActive then
            BURST_START = 175
        end
        stopAnim()
        getgenv().Sound6DSL(SOUNDS.RUN_LOOP)
        getgenv().Sound6D(SOUNDS.RUN_STOP, 1, false)
        getgenv().Sound6D(SOUNDS.SLIDE, 1, false)
        playAnim(ANIMS.SLIDE, 1, false)
        getgenv().Sound6DLoop(SOUNDS.IDLE)
        -- Let physics carry the slide naturally.
        -- The moment the slide anim finishes, kill horizontal velocity dead.
        task.spawn(function()
            getgenv().Animation.Completed:Wait()
            if currentState ~= "idle" then return end  -- bailed out (started running again)
            local vel = rootPart.AssemblyLinearVelocity
            rootPart.AssemblyLinearVelocity = Vector3.new(0, vel.Y, 0)
        end)

    elseif newState == "fastrun" then
        setEffectEnabled(true)
        stopAnim()
        getgenv().Sound6DSL(SOUNDS.IDLE)
        getgenv().Sound6D(SOUNDS.RUN_START, 1, false)
        getgenv().Sound6DLoop(SOUNDS.RUN_LOOP)
        playAnim(ANIMS.FAST_RUN, 1, true)

    elseif newState == "jump" then
        setEffectEnabled(false)
        stopAnim()
        getgenv().Sound6DSL(SOUNDS.RUN_LOOP)
        playAnim(ANIMS.JUMP, 1, false)
        task.spawn(function()
            getgenv().Animation.Completed:Wait()
            if currentState ~= "jump" then return end
            if humanoid:GetState() == Enum.HumanoidStateType.Freefall then
                transitionTo("jumploop", 0)
            else
                transitionTo("idle", 0)
            end
        end)

    elseif newState == "jumploop" then
        stopAnim()
        playAnim(ANIMS.JUMP_LOOP, 1, true)
    end
end

-- ── 8. Running state resolver ─────────────────────
-- !! Do not update this unless prompted to. Even slight changes can break them !!
local function resolveRunningState(ws, moving)
    if not moving or ws <= SPEED_RUN then
        return "idle"
    else
        return "fastrun"
    end
end

-- ── CHARGE BOOST FUNCTION BODIES ──────────────────────────────────────
-- Defined here so that playAnim / stopAnim / transitionTo /
-- resolveRunningState are all in scope as valid locals.

cancelChargeBoost = function()
    chargeBoostHeld  = false
    boostCharging    = false
    startupComplete  = false
    chargeHoldTime   = 0
    chargeBoostSpeed = 0

    if chargeCompletedConn then
        chargeCompletedConn:Disconnect()
        chargeCompletedConn = nil
    end
    if chargeBoostLoopConn then
        chargeBoostLoopConn:Disconnect()
        chargeBoostLoopConn = nil
    end

    -- Undo any live speed ramping that happened during the charge
    humanoid.WalkSpeed = preBoostSavedSpeed
    savedSpeed         = preBoostSavedSpeed
    BURST_START        = 175

    stopAnim()
    setEffectEnabled(false)
    setChargeEffectEnabled(false)
    chargeBoostBtn.ImageTransparency = 0.4
    getgenv().Sound6DSL(SOUNDS.BOOST_CHARGE)

    -- Re-sync locomotion to whatever state the player is actually in
    currentState = nil
    local ws     = (rootPart.AssemblyLinearVelocity * Vector3.new(1,0,1)).Magnitude
    local moving = humanoid.MoveDirection.Magnitude > 0.1
    transitionTo(resolveRunningState(ws, moving), ws)
end

triggerBoostActivation = function()
    local speedToApply = startupComplete and chargeBoostSpeed or 0

    chargeBoostHeld  = false
    boostCharging    = false
    startupComplete  = false
    chargeHoldTime   = 0

    if chargeCompletedConn then
        chargeCompletedConn:Disconnect()
        chargeCompletedConn = nil
    end
    if chargeBoostLoopConn then
        chargeBoostLoopConn:Disconnect()
        chargeBoostLoopConn = nil
    end

    chargeBoostBtn.ImageTransparency = 0.4

    if speedToApply > 0 then
        -- preBoostSavedSpeed captured at startChargeBoost; BURST_START already live-updated
        humanoid.WalkSpeed = speedToApply
        savedSpeed         = speedToApply
        BURST_START        = 1000
        boostActive        = true
        setEffectEnabled(true)
        setChargeEffectEnabled(false)
        getgenv().Sound6DSL(SOUNDS.BOOST_CHARGE)
        getgenv().Sound6D(SOUNDS.BOOST_RELEASE, 2.5, false)

        -- BOOM: inject velocity immediately instead of relying on the Heartbeat race.
        -- Without this, the main Heartbeat often fires first with the old BURST_START (175),
        -- sets wasMov = true, and the boost kick never fires — causing the slow catchup.
        local moveDir = humanoid.MoveDirection
        if moveDir.Magnitude > 0.1 then
            local vel = rootPart.AssemblyLinearVelocity
            rootPart.AssemblyLinearVelocity = Vector3.new(
                moveDir.X * speedToApply,
                vel.Y,
                moveDir.Z * speedToApply
            )
        end
        -- Mark as moving so the Heartbeat burst doesn't double-fire
        wasMov = true
        -- Camera slam — you just hit max boost speed, the camera should feel it
        CurrentShaker:Shake(ShakePresets.BoostFire())

        -- Locomotion state machine can take over now (boostCharging = false)
        currentState = nil
        local ws     = (rootPart.AssemblyLinearVelocity * Vector3.new(1,0,1)).Magnitude
        local moving = humanoid.MoveDirection.Magnitude > 0.1
        transitionTo(resolveRunningState(ws, moving), ws)

        -- After 8 seconds snap back to regular speed and restore BURST_START
        task.delay(CHARGE_BOOST_DURATION, function()
            if boostActive then
                boostActive        = false
                humanoid.WalkSpeed = preBoostSavedSpeed
                savedSpeed         = preBoostSavedSpeed
                BURST_START        = 175
                setEffectEnabled(false)
            end
        end)
    else
        -- Startup hadn't completed — no speed boost, just clean up
        stopAnim()
        setEffectEnabled(false)
        currentState = nil
        local ws     = (rootPart.AssemblyLinearVelocity * Vector3.new(1,0,1)).Magnitude
        local moving = humanoid.MoveDirection.Magnitude > 0.1
        transitionTo(resolveRunningState(ws, moving), ws)
    end

    chargeBoostSpeed = 0
end

startChargeBoost = function()
    if not speedEnabled then return end
    if boostCharging    then return end  -- already charging

    -- Capture pre-boost speed NOW before any ramping touches savedSpeed
    preBoostSavedSpeed = savedSpeed

    chargeBoostHeld  = true
    boostCharging    = true
    startupComplete  = false
    chargeHoldTime   = 0
    chargeBoostSpeed = 0

    chargeBoostBtn.ImageTransparency = 0
    setEffectEnabled(true)
    setChargeEffectEnabled(true)
    getgenv().Sound6DLoop(SOUNDS.BOOST_CHARGE, 1.5)

    -- Play startup animation (non-looped)
    playAnim(ANIMS.BOOST_STARTUP, 1, false)

    -- Once startup finishes, switch to the boost loop
    chargeCompletedConn = getgenv().Animation.Completed:Connect(function()
        if chargeCompletedConn then
            chargeCompletedConn:Disconnect()
            chargeCompletedConn = nil
        end
        if boostCharging and chargeBoostHeld then
            startupComplete = true
            playAnim(ANIMS.BOOST_LOOP, 1, true)
        end
    end)

    -- Heartbeat: ramp boost speed live (like speedup does) and detect movement
    chargeBoostLoopConn = RunService.Heartbeat:Connect(function(dt)
        if not chargeBoostHeld then return end

        chargeHoldTime   += dt
        chargeBoostSpeed  = math.min(
            CHARGE_BOOST_MAX_SPEED,
            (chargeHoldTime / CHARGE_BOOST_MAX_TIME) * CHARGE_BOOST_MAX_SPEED
        )

        -- Push the ramped speed live so you feel it building while holding
        if chargeBoostSpeed > 0 then
            humanoid.WalkSpeed = chargeBoostSpeed
            savedSpeed         = chargeBoostSpeed
            BURST_START        = chargeBoostSpeed - 200
        end

        if humanoid.MoveDirection.Magnitude > 0.1 then
            if chargeBoostLoopConn then
                chargeBoostLoopConn:Disconnect()
                chargeBoostLoopConn = nil
            end
            triggerBoostActivation()
        end
    end)
end

stopChargeBoost = function()
    if not boostCharging then return end
    cancelChargeBoost()
end

-- ── 9. humanoid.Running — primary locomotion driver ──
-- !! Do not update this unless prompted to. Even slight changes can break them !!
humanoid.Running:Connect(function(ws)
    local hs = humanoid:GetState()
    if hs == Enum.HumanoidStateType.Jumping
    or hs == Enum.HumanoidStateType.Freefall then return end

    local moving  = humanoid.MoveDirection.Magnitude > 0.1
    local desired = resolveRunningState(ws, moving)

    if desired == currentState then
        if currentState == "fastrun" then
            setLiveSpeed(1)
        end
        return
    end

    transitionTo(desired, ws)
end)

-- ── 10. humanoid.StateChanged — jump / freefall / land ──
-- !! Do not update this unless prompted to. Even slight changes can break them !!
local HumState = Enum.HumanoidStateType

humanoid.StateChanged:Connect(function(_, new)
    if new == HumState.Jumping then
        transitionTo("jump", 0)

    elseif new == HumState.Freefall then
        if currentState ~= "jump" then
            transitionTo("jumploop", 0)
        end

    elseif new == HumState.Landed
        or new == HumState.Running
        or new == HumState.RunningNoPhysics then
        if currentState == "jump" or currentState == "jumploop" then
            local ws     = (rootPart.AssemblyLinearVelocity * Vector3.new(1,0,1)).Magnitude
            local moving = humanoid.MoveDirection.Magnitude > 0.1
            transitionTo(resolveRunningState(ws, moving), ws)
        end
    end
end)

-- ── 11. Live speed sync poll ──────────────────────
local pollTimer = 0
RunService.RenderStepped:Connect(function(dt)
    pollTimer += dt
    if pollTimer < 0.1 then return end
    pollTimer = 0

    local ws = (rootPart.AssemblyLinearVelocity * Vector3.new(1,0,1)).Magnitude

    -- Toggle trails based on speed threshold
    local trailsOn = ws > SPEED_RUN
    for _, t in ipairs(activeTrails) do
        if t.Parent then
            t.Enabled = trailsOn
        end
    end

    -- Nudge run playback speed live
    if currentState == "fastrun" then
        setLiveSpeed(1)
    end
end)

-- ── 11b. Instant-turn / no-slide fix ─────────────
-- Every physics frame, if the player is above the fast-run threshold AND
-- is actively steering, snap horizontal velocity to match MoveDirection.
-- This kills the sideways momentum that causes sliding on turns.
local lastTurnSoundTime = 0
RunService.Heartbeat:Connect(function()
    local moveDir = humanoid.MoveDirection
    if moveDir.Magnitude < 0.1 then return end          -- not steering, leave physics alone

    local vel   = rootPart.AssemblyLinearVelocity
    local hVel  = Vector3.new(vel.X, 0, vel.Z)
    local speed = hVel.Magnitude
    if speed < SPEED_RUN then return end                 -- only fix above fast-run speed

    -- Detect a sharp turn: dot product between current velocity dir and new move dir
    -- A dot near -1 = full 180°, near 0 = 90°. Trigger below 0.4 (roughly 66°+).
    local velDir = hVel.Unit
    local dot    = velDir:Dot(moveDir)
    if dot < 0.4 then
        local now = tick()
        if now - lastTurnSoundTime > 0.4 then           -- debounce so it doesn't spam
            lastTurnSoundTime = now

     CurrentShaker:Shake(ShakePresets.BoostFire())
            getgenv().Sound6D(SOUNDS.RUN_START, 2.5, false)
        end
    end

    -- Redirect horizontal velocity to the new move direction at the same speed.
    -- Y is untouched so jumps / gravity are never affected.
    local snapped = moveDir * speed
    rootPart.AssemblyLinearVelocity = Vector3.new(snapped.X, vel.Y, snapped.Z)
end)

