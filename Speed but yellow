-- Spawn a moving surface light between two world positions
local function ActiveLight(posA, posB, color)
	local part             = Instance.new("Part")
	part.Anchored          = true
	part.CanCollide        = false
	part.CanTouch          = false
	part.CanQuery          = false
	part.Transparency      = 1
	part.CastShadow        = false
	local dist             = (posA - posB).Magnitude
	part.Size              = Vector3.new(3, 0.1, math.clamp(dist * 1.2, dist, dist + 20))
	part.CFrame            = CFrame.new(posB, posA)
	part.Position          = (posA + posB) / 2
	local light            = Instance.new("SurfaceLight")
	light.Color            = color
	light.Range            = 10
	light.Angle            = 180
	light.Shadows          = false
	light.Brightness       = shared.Flashtime and 0.25 or 0.75
	light.Face             = Enum.NormalId.Bottom
	light.Parent           = part
	part.Parent            = Workspace:FindFirstChild("ScriptDebris")
	TweenService:Create(light, TweenInfo.new(0.1 * (shared.Flashtime and 20 or 1), Enum.EasingStyle.Linear), { Brightness = 0 }):Play()
	Debris:AddItem(part, 0.5 * (shared.Flashtime and 20 or 1))
end

-- Register a character and build all its VFX objects
function VFX.Activate(character)
	if VFX.Users[character] ~= nil then return end

	VFX.Users[character] = { true }
	character:SetAttribute("LastCWupdate", 0)
	character:SetAttribute("LastPos", nil)

	if not character:FindFirstChild("CW_Trails") then
		local folder     = Instance.new("Folder")
		folder.Name      = "CW_Trails"
		folder.Parent    = character

		-- Particle emitters on every relevant body part
		local excluded   = { "HumanoidRootPart", "WaterParticle", "SonicBoomParticle" }
		for _, part in pairs(character:GetChildren()) do
			if part:IsA("BasePart") and not table.find(excluded, part.Name) then
				local p    = CreateParticle()
				p.Parent   = part
				p.Enabled  = true
			end
		end

		character:SetAttribute("LastTrailColor", 1)
		local humanoid   = character:FindFirstChildOfClass("Humanoid")
		local hipScale   = ((humanoid and humanoid.HipHeight) or 2) / 2
		VFX.Users[character][3] = hipScale

		-- Build one trail per vertical offset (alternating Primary / Secondary)
		_lastTrailType = "Secondary"
		for _, yOffset in ipairs(TRAIL_Y_OFFSETS) do
			local scaledY  = yOffset * hipScale
			local trail    = CreateTrail()
			if _lastTrailType == "Secondary" then
				trail:SetAttribute("Type", "Primary")
				_lastTrailType = "Primary"
			else
				trail:SetAttribute("Type", "Secondary")
				_lastTrailType = "Secondary"
			end
			local att0     = CreateTorsoAttachment(character)
			local att1     = CreateTorsoAttachment(character)
			att0.Name      = "CWattachment"
			att1.Name      = "CWattachment"
			trail.Attachment0 = att0
			trail.Attachment1 = att1
			trail.Name     = tostring(scaledY)
			trail.Parent   = folder
		end
		_lastTrailType = nil
	end

	-- Auto-clean when the character is removed
	VFX.Users[character][2] = character.AncestryChanged:Connect(function()
		DestroyUserTable(character)
	end)
end

-- Tear down all VFX for a character
function VFX.Deactivate(character)
	DestroyUserTable(character)
end

-- Main per-frame update
RunService.Heartbeat:Connect(function()
	for character, userData in pairs(VFX.Users) do
		local root     = character:FindFirstChild("HumanoidRootPart")
		local humanoid = character:FindFirstChild("Humanoid")

		-- Clean up dead characters
		if humanoid and humanoid.Health <= 0 then
			DestroyUserTable(character)
			continue
		end

		if not root then continue end
		if (Camera.CFrame.Position - root.Position).Magnitude > 250 then continue end

		local isGacha      = character:GetAttribute("Gacha") or false
		local now          = tick()
		local shouldUpdate = now >= (character:GetAttribute("LastCWupdate") or 0)

		-- Velocity
		local velocity = (root.AssemblyLinearVelocity * Vector3.new(1, 0.5, 1)).Magnitude
		local aboveSpeed = velocity > (shared.Flashtime and 0.1 or SPEED_THRESHOLD)

		-- Particle rate on all body parts (only push rate when above speed)
		local moveDir = character:FindFirstChild("MoveDirection")
		local moveMag = moveDir and moveDir.Value.Magnitude or 0
		local pRate   = aboveSpeed and (1 + 4 * moveMag) * 5 or 0

		for _, part in pairs(character:GetChildren()) do
			if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
				local p = part:FindFirstChild("CW_Particle")
				if p then
					local rate = pRate > 0 and pRate + math.random(-3, 3) or 0
					TweenService:Create(p, TweenInfo.new(0.5), {
						Rate      = rate,
						TimeScale = shared.Flashtime and 0.05 or 1,
					}):Play()
					p.Color         = ColorSequence.new(GetLightningColor())
					p.LightEmission = IsDark(p.Color) and 0 or 1
				end
			end
		end

		-- Idle ambient lightning lights (only when above speed)
		if aboveSpeed and shouldUpdate
			and shared.PerformanceMode ~= true then
			IdleLight(character, GetLightningColor())
		end

		if shouldUpdate then
			character:SetAttribute("LastCWupdate", now + (shared.Flashtime and 0.25 or 0.05))
		end

		-- Active moving light between last and current position
		if aboveSpeed
			and shared.PerformanceMode ~= true then
			local hipPos  = (root.CFrame * CFrame.new(0, humanoid.HipHeight * 1.176, 0)).Position
			local lastPos = character:GetAttribute("LastPos") or hipPos
			if lastPos ~= hipPos then
				ActiveLight(hipPos, lastPos, GetLightningColor(character, true))
			end
			character:SetAttribute("LastPos", hipPos)
		else
			character:SetAttribute("LastPos", root.CFrame.Position)
		end

		-- Trail objects
		local trailFolder = character:FindFirstChild("CW_Trails")
		if trailFolder then
			for _, trail in pairs(trailFolder:GetChildren()) do
				trail.Enabled = aboveSpeed  -- only visible above SPEED_THRESHOLD

				-- Colour
				if trail:GetAttribute("Type") == "Secondary" then
					trail.Color = ColorSequence.new(GetLightningColor(character, false))
				else
					trail.Color = ColorSequence.new(primaryColor or COLOR_DATA)
				end
				trail.LightEmission = IsDark(trail.Color) and 0 or 1

				-- Geometry / texture (only on update tick, skip the "Blur" trail)
				if trail.Name ~= "Blur"
					and shouldUpdate
					and trail.Attachment0 ~= nil
					and trail.Attachment1 ~= nil then

					local hipScale   = userData[3] or 1
					local a0, a1     = NewAttachmentPositions(hipScale, tonumber(trail.Name) or 0)
					if not shared.Flashtime then
						trail.Attachment0.Position = a0
						trail.Attachment1.Position = a1
					else
						TweenService:Create(trail.Attachment0, TweenInfo.new(0.25), { Position = a0 }):Play()
						TweenService:Create(trail.Attachment1, TweenInfo.new(0.25), { Position = a1 }):Play()
					end

					local width = math.random(3, 15) / 10
					trail.WidthScale = NumberSequence.new({
						NumberSequenceKeypoint.new(0, width),
						NumberSequenceKeypoint.new(1, 0),
					})

					local lifetime = math.random(10, 15) / 100
					if shared.Flashtime then lifetime = lifetime * 20 end
					trail.Lifetime = lifetime * (isGacha and shared.Flashtime and 2000 or 1)

					trail.TextureLength = shared.Flashtime
						and 4.2 + velocity / 12
						or  4.2 + velocity / 150

					trail.Transparency = NumberSequence.new({
						NumberSequenceKeypoint.new(0,   1),
						NumberSequenceKeypoint.new(0.1, 0),
						NumberSequenceKeypoint.new(0.9, 0),
						NumberSequenceKeypoint.new(1,   1),
					})

					trail.Texture = TRAIL_TEXTURES[math.random(1, #TRAIL_TEXTURES)]
				end
			end
		end
	end
end)

