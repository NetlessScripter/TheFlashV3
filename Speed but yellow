-- Kill the default Animate script immediately so it never plays
-- its own walk/run/idle over our animations.
local function suppressDefaultAnims(char)
    local animate = char:FindFirstChild("Animate")
    if animate then animate.Disabled = true end
    local animator = char:FindFirstChildOfClass("Humanoid")
    animator = (animator or humanoid):FindFirstChildOfClass("Animator")
    if animator then
        for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
            track:Stop(0)
        end
    end
end

