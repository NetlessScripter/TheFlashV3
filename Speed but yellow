local function setSpeed(enabled)
    speedEnabled = enabled
    if enabled then
        humanoid.WalkSpeed        = savedSpeed
        btn.ImageTransparency     = 0       -- full brightness = ON
    else
        humanoid.WalkSpeed        = BASE_SPEED
        btn.ImageTransparency     = 0.4    -- dimmed = OFF
        wasMov = false
        stopBoost()
        stopDecrease()
        -- Cancel any charge boost that may be in progress or active
        boostActive = false   -- prevent the boost timer callback from restoring speed
        if boostCharging then
            cancelChargeBoost()
        end
        -- Stop run sounds and revert to idle sound
        -- Sound6DStop kills every active sound at once (loops + one-shots)
        if getgenv().Sound6DStop then
            getgenv().Sound6DStop()
        end
        currentState = nil
        setEffectEnabled(false)
    end
end

