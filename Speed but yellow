-- Hold logic for both buttons
local boostHeld        = false
local boostConnection  = nil
local decHeld          = false
local decConnection    = nil

local function startBoost()
    if not speedEnabled then return end
    boostHeld = true
    boostBtn.ImageTransparency = 0
    boostConnection = RunService.Heartbeat:Connect(function(dt)
        if not boostHeld or not speedEnabled then
            boostHeld = false
            boostBtn.ImageTransparency = 0.4
            if boostConnection then boostConnection:Disconnect(); boostConnection = nil end
            return
        end
        humanoid.WalkSpeed = math.min(BOOST_MAX, humanoid.WalkSpeed + (260 * dt))
        savedSpeed = humanoid.WalkSpeed
    end)
end

local function stopBoost()
    boostHeld = false
    boostBtn.ImageTransparency = 0.4
    if boostConnection then boostConnection:Disconnect(); boostConnection = nil end
end

local function startDecrease()
    if not speedEnabled then return end
    decHeld = true
    decreaseBtn.ImageTransparency = 0
    decConnection = RunService.Heartbeat:Connect(function(dt)
        if not decHeld or not speedEnabled then
            decHeld = false
            decreaseBtn.ImageTransparency = 0.4
            if decConnection then decConnection:Disconnect(); decConnection = nil end
            return
        end
        humanoid.WalkSpeed = math.max(BOOST_MIN, humanoid.WalkSpeed - (260 * dt))
        savedSpeed = humanoid.WalkSpeed
    end)
end

local function stopDecrease()
    decHeld = false
    decreaseBtn.ImageTransparency = 0.4
    if decConnection then decConnection:Disconnect(); decConnection = nil end
end

