local ANIMS = {
    FAST_RUN      = "rbxassetid://13811491770",
    JUMP          = "rbxassetid://10921160088",
    JUMP_LOOP     = "rbxassetid://10921159222",
    SLIDE         = "rbxassetid://13926813279",
